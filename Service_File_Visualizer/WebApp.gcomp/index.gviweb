								<NodeLabel AttachedTo="6d18cf8cd304f87bbb4583c8125c0c7" Bounds="18 335 72 14" Id="f3c1a273e370470cb61061e950d48ca7" xmlns="http://www.ni.com/PlatformFramework">
									<p.Text>Page content</p.Text>
								</NodeLabel>
								<OneButtonDialog Bounds="930 240 40 40" Id="e65463d4ebcf461587e3cb66ebc50603" />
								<Literal Bounds="440 240 465 95" DataType="String" Id="e8120e9fb7ed43f7b9136c60c24b12e2" Label="fb3ca9ff25f34873b665b8050c6a14a2" xmlns="http://www.ni.com/MocCommon">
									<p.Data>"Page contents:\n\nPage 1: \n- Common Information.\n- Basic Settings.\n- Diagnostic Real Time Data Sensors.\n- Diagnostic RT Calibration.\n- Diagnostic Water iCS Switch.\n- Diagnostic Service History.\n- Diagnostic RunningTimes Components.\n- Software Version History.\n\nPage 2: \n- Histogram temperature CPU &amp; IO.\n- Diagnostic RunningTimes Modes.\n- System Logger, Histogram temperature LEDs.\n- Histogram temperature pump pcb &amp; Gas box.\n- Histogram temperature pump pcb &amp; Histogram Fan 1 RPM &amp; Power.\n- Component Replacement History.\n\nPage 3: \n- Histogram Fan1 Temp.&amp;Voltages.\n- Histogram Fan 2 RPM &amp; Power.\n- Histogram Fan2 Temp.&amp;Voltages.\n- Histogram Fan 3 RPM &amp; Power.\n- Histogram Fan3 Temp.&amp;Voltages.\n- Histogram MMI.\n- System OnOff History.\n     \nPage 4: \n- Histogram Basis CPU &amp; RAM Load, \n- Histogram Magnetron Temperature (iHexagon) &amp; Power.\n- Histogram Power Supply Temperature (iHexagon).\n- Service report XML File Content."</p.Data>
									<StringBehavior SizeToContent="False" TextDisplayMode="Default" />
								</Literal>
								<NodeLabel AttachedTo="e8120e9fb7ed43f7b9136c60c24b12e2" Bounds="440 222 30 15" Id="fb3ca9ff25f34873b665b8050c6a14a2" Visible="False" xmlns="http://www.ni.com/PlatformFramework">
									<p.Text>message</p.Text>
								</NodeLabel>
